# Supabase 接続情報のテンプレート
# 1. https://supabase.com/dashboard で iHub プロジェクトを開く
# 2. 左メニュー → Project Settings → API
# 3. 各値をコピーして .env.local に記入
# 4. .env.local は .gitignore 済（git に push されない）

# Project URL（公開URL）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Publishable key（旧 anon key、ブラウザ用、公開OK、RLS で保護）
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Secret key（旧 service_role key、サーバー専用、絶対公開不可）
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# 環境フラグ
NEXT_PUBLIC_APP_ENV=development  # development | staging | production
