{
  "name": "ihub-platform",
  "private": true,
  "workspaces": [
    "web",
    "mobile",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:lint": "npm --prefix web run lint",
    "mobile:start": "npm --prefix mobile run start",
    "mobile:ios": "npm --prefix mobile run ios",
    "mobile:typecheck": "npm --prefix mobile run typecheck",
    "core:typecheck": "mobile/node_modules/.bin/tsc -p packages/core/tsconfig.json --noEmit",
    "design:typecheck": "mobile/node_modules/.bin/tsc -p packages/design/tsconfig.json --noEmit",
    "supabase:typecheck": "mobile/node_modules/.bin/tsc -p packages/supabase/tsconfig.json --noEmit",
    "packages:typecheck": "npm run core:typecheck && npm run design:typecheck && npm run supabase:typecheck",
    "typecheck": "npm run mobile:typecheck && npm run packages:typecheck"
  }
}
